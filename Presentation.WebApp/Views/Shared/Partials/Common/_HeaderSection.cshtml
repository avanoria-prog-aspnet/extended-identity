@{

}

<section class="section__header">
    <div class="logotype">
        <a href="/"><img src="~/images/logotype.png" alt="CoreFitness Logotype" /></a>
    </div>
    <nav class="main-menu">
        <ul class="menu">
            <li class="menu-item">
                <a class="menu-item-link" asp-action="Index" asp-controller="FitnessCenters">Fitness Centers</a>
            </li>
            <li class="menu-item">
                <a class="menu-item-link" asp-action="Index" asp-controller="Memberships">Memberships</a>
            </li>
            <li class="menu-item">
                <a class="menu-item-link" asp-action="Index" asp-controller="Training">Training</a>
            </li>
            <li class="menu-item">
                <a class="menu-item-link" asp-action="Index" asp-controller="Support">Customer Service</a>
            </li>
        </ul>
    </nav>
    <nav class="account-menu">
        <ul class="menu">
            @if (User.Identity?.IsAuthenticated == true) {
                <li class="menu-item">
                    <a class="menu-item-link" asp-area="Authentication" asp-action="SignOut" asp-controller="Authentication">SignOut</a>
                </li>

                @if (User.IsInRole("Admin") || User.IsInRole("Employee"))
                {
                    <li class="menu-item">
                        <a class="btn accent" asp-area="Admin" asp-action="Index" asp-controller="AdminDashboard">Admin Center</a>
                    </li>
                }
                else
                {
                    <li class="menu-item">
                        <a class="btn accent" asp-area="Me" asp-action="Index" asp-controller="Me">My Account</a>
                    </li>
                }
            }
            else
            {
                <li class="menu-item">
                    <a class="menu-item-link" asp-area="Authentication" asp-action="SignUp" asp-controller="Authentication">Become Member</a>
                </li>

                <li class="menu-item">
                    <a class="btn accent" asp-area="Authentication" asp-action="SignIn" asp-controller="Authentication">Sign In</a>
                </li>
            }
        </ul>
    </nav>

    <button id="mobile-menu-button" data-target="#mobile-menu-flyout" class="mobile-btn accent"></button>

</section>